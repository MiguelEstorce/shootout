package model;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.util.ArrayList;

public class DAO {

    // Conexão
    private String driver = "com.mysql.cj.jdbc.Driver";
    private String url = "jdbc:mysql://127.0.0.1:3306/shootout?useTimezone=true&serverTimezone=UTC";
    private String user = "root";
    private String password = "migueldados";

    private Connection conectar() {
        Connection con = null;
        try {
            Class.forName(driver);
            con = DriverManager.getConnection(url, user, password);
            return con;
        } catch (Exception e) {
            System.out.println(e);
            return null;
        }
    }

    // TESTE CONEXÃO
    public void testeConexao() {
        try {
            Connection con = conectar();
            System.out.println(con);
            con.close();
        } catch (Exception e) {
            System.out.println(e);
        }
    }

        // LISTAR PRODUTOS
    
    public ArrayList<JavaBeans> listarProduto() {

        ArrayList<JavaBeans> lista = new ArrayList<>();

        String sql = "SELECT * FROM produto ORDER BY nome";

        try (Connection con = conectar();
             PreparedStatement pst = con.prepareStatement(sql);
             ResultSet rs = pst.executeQuery()) {

            while (rs.next()) {

                JavaBeans p = new JavaBeans();

                p.setIdcon(rs.getString("idcon"));
                p.setNome(rs.getString("nome"));
                p.setDescricao(rs.getString("descricao"));
                p.setQuantidade(rs.getInt("quantidade"));
                p.setPreco(rs.getDouble("preco"));

                lista.add(p);
            }

        } catch (Exception e) {
            System.out.println(e);
        }

        return lista;
    }
    
    public void inserirProdutos(JavaBeans produto) {

        String sql = "INSERT INTO produto (nome, descricao, quantidade, preco) VALUES (?, ?, ?, ?)";

        try (Connection con = conectar();
             PreparedStatement pst = con.prepareStatement(sql)) {

            pst.setString(1, produto.getNome());
            pst.setString(2, produto.getDescricao());
            pst.setInt(3, produto.getQuantidade());
            pst.setDouble(4, produto.getPreco());

            pst.executeUpdate();

        } catch (Exception e) {
            System.out.println(e);
        }
    }

    // ======================
    // DELETAR
    // ======================
    public void deletarProduto(JavaBeans produto) {

        String sql = "DELETE FROM produto WHERE idcon=?";

        try (Connection con = conectar();
             PreparedStatement pst = con.prepareStatement(sql)) {

            pst.setString(1, produto.getIdcon());
            pst.executeUpdate();

        } catch (Exception e) {
            System.out.println(e);
        }
    }

    // ======================
    // SELECIONAR UM
    // ======================
    public void selecionarProduto(JavaBeans produto) {

        String sql = "SELECT * FROM produto WHERE idcon = ?";

        try (Connection con = conectar();
             PreparedStatement pst = con.prepareStatement(sql)) {

            pst.setString(1, produto.getIdcon());

            ResultSet rs = pst.executeQuery();

            if (rs.next()) {

                produto.setIdcon(rs.getString("idcon"));
                produto.setNome(rs.getString("nome"));
                produto.setDescricao(rs.getString("descricao"));
                produto.setQuantidade(rs.getInt("quantidade"));
                produto.setPreco(rs.getDouble("preco"));
            }
            con.close();

        } catch (Exception e) {
            System.out.println(e);
        }
    }

    // ======================
    // EDITAR
    // ======================
    public void editarProduto(JavaBeans produto) {

        String sql = "UPDATE produto SET nome=?, descricao=?, quantidade=?, preco=? WHERE idcon=?";

        try (Connection con = conectar();
             PreparedStatement pst = con.prepareStatement(sql)) {

            pst.setString(1, produto.getNome());
            pst.setString(2, produto.getDescricao());
            pst.setInt(3, produto.getQuantidade());
            pst.setDouble(4, produto.getPreco());
            pst.setString(5, produto.getIdcon());

            pst.executeUpdate();
            int linhas = pst.executeUpdate();
            System.out.println("Linhas afetadas: " + linhas);

        } catch (Exception e) {
            System.out.println(e);
        }
    }
}
